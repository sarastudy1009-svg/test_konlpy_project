# 파이참 프로젝트와 github 저장소 연결:
git remote add origin https://github.com/sarastudy1009-svg/test_konlpy_project.git

# 연결 확인:
git remote -v
# 표시되면 연결 성공임
origin  https://github.com/sarastudy1009-svg/test_konlpy_project.git (fetch)
origin  https://github.com/sarastudy1009-svg/test_konlpy_project.git (push)

# .gitignore 작성 : git 에 업로드하면 안되는 파일들 설정

# git 메뉴 > commit > 커밋 메세지 작성 > 커밋 클릭
# 터미널로 하면 :
git add .
git commit -m "Initial Commit"

# 브렌치(branch) 확인
git branch
# 출력 확인:
*master
또는
*main

# 만약 master 라면 main 으로 변경
git branch -M main
# 확인
git branch
# 출력 확인
*main

# 최초 업로드 : Main 브렌치 push
git push -u origin main
# 옵션 설명
# -u : 현재 브랜치(main)와 GitHub의 main을 연결
